---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact" description="Get in touch with Lucky at healthwelltech21.">
  <Header slot="header" />

  <section class="contact">
    <div class="contact__container">
      <h1 class="contact__title">Get in Touch</h1>
      <p class="contact__intro">Have a question, suggestion, or just want to say hi? I'd love to hear from you. Fill out the form below and I'll get back to you as soon as I can.</p>

      <form class="contact__form" action="mailto:hello@healthwelltech21.com" method="POST" enctype="text/plain">
        <div class="contact__field">
          <label for="contact-name" class="contact__label">Name</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            class="contact__input"
            placeholder="Your name"
          />
        </div>

        <div class="contact__field">
          <label for="contact-email" class="contact__label">Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            class="contact__input"
            placeholder="your@email.com"
          />
        </div>

        <div class="contact__field">
          <label for="contact-message" class="contact__label">Message</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="6"
            class="contact__textarea"
            placeholder="What's on your mind?"
          ></textarea>
        </div>

        <button type="submit" class="contact__submit">Send Message</button>
      </form>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .contact {
    padding: var(--space-9) var(--space-5);
  }

  .contact__container {
    max-width: 560px;
    margin: 0 auto;
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--space-4) 0;
  }

  .contact__intro {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--charcoal);
    margin: 0 0 var(--space-7) 0;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact__label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink);
  }

  .contact__input,
  .contact__textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--sage-soft);
    border-radius: 4px;
    background: white;
    color: var(--charcoal);
    transition: border-color 200ms ease;
  }

  .contact__input:focus,
  .contact__textarea:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 2px rgba(184, 101, 74, 0.2);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 140px;
  }

  .contact__submit {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--sage-deep);
    color: var(--ivory);
    border: none;
    border-radius: 4px;
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    transition: opacity 200ms ease;
    align-self: flex-start;
  }

  .contact__submit:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .contact {
      padding: var(--space-7) var(--space-4);
    }
  }
</style>
