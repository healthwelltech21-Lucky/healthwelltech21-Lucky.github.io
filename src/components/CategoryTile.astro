---
interface Props {
  name: string;
  slug: string;
  image: string;
}

const { name, slug, image } = Astro.props;
---

<article class="category-tile">
  <a href={`/categories/${slug}`} class="category-tile__link">
    <img src={image} alt="" class="category-tile__image" loading="lazy" />
    <div class="category-tile__overlay"></div>
    <span class="category-tile__name">{name}</span>
  </a>
</article>

<style>
  .category-tile {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 8px;
    background: var(--sage-mid);
  }

  .category-tile__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .category-tile__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 800ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .category-tile:hover .category-tile__image {
    transform: scale(1.05);
  }

  .category-tile__overlay {
    position: absolute;
    inset: 0;
    background: rgba(45, 42, 38, 0.4);
    pointer-events: none;
  }

  .category-tile__name {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ivory);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    text-align: center;
    pointer-events: none;
  }
</style>
