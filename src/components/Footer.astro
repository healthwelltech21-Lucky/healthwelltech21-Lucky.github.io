---
const categories = [
  { label: 'Clean Beauty', href: '/categories/clean-beauty' },
  { label: 'Gentle Wellness', href: '/categories/gentle-wellness' },
  { label: 'Organic Pantry', href: '/categories/organic-pantry' },
  { label: 'Endo-Friendly Living', href: '/categories/endo-friendly-living' },
  { label: 'Slow Living', href: '/categories/slow-living' },
  { label: 'Smart Home', href: '/categories/smart-home' },
];

const links = [
  { label: 'About', href: '/about' },
  { label: 'Start Here', href: '/start-here' },
  { label: 'Contact', href: '/contact' },
  { label: 'Disclosure', href: '/disclosure' },
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
];
---

<footer class="bg-[var(--sage-deep)] text-[var(--ivory)] mt-[var(--space-9)]">
  <div class="max-w-7xl mx-auto px-[var(--space-5)] py-[var(--space-8)]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--space-7)]">
      <div>
        <a href="/" class="inline-block no-underline mb-[var(--space-4)]">
          <span class="font-[var(--font-display)] text-[var(--ivory)] text-xl font-[320] tracking-[-0.03em]">healthwelltech</span><span class="font-[var(--font-body)] text-[var(--ivory)] text-xs font-medium relative top-[-4px] ml-1 border-b border-[var(--ivory)]">21</span>
        </a>
        <p class="text-[var(--sage-soft)] text-sm leading-relaxed mt-[var(--space-3)]">Slow living, clean choices, gentle wellness.</p>
        <div class="flex gap-[var(--space-4)] mt-[var(--space-5)]">
          <a href="https://www.instagram.com/healthwelltech21" target="_blank" rel="noopener" aria-label="Instagram" class="text-[var(--sage-soft)] hover:text-[var(--ivory)] transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://pinterest.com/healthwelltech21" target="_blank" rel="noopener" aria-label="Pinterest" class="text-[var(--sage-soft)] hover:text-[var(--ivory)] transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-[var(--font-body)] text-xs font-semibold uppercase tracking-[0.18em] text-[var(--sage-soft)] mb-[var(--space-4)]">Categories</h4>
        <ul class="list-none m-0 p-0 space-y-[var(--space-2)]">
          {categories.map(cat => (
            <li><a href={cat.href} class="text-[var(--ivory)] no-underline text-sm hover:text-[var(--sage-soft)] transition-colors">{cat.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-[var(--font-body)] text-xs font-semibold uppercase tracking-[0.18em] text-[var(--sage-soft)] mb-[var(--space-4)]">Links</h4>
        <ul class="list-none m-0 p-0 space-y-[var(--space-2)]">
          {links.map(link => (
            <li><a href={link.href} class="text-[var(--ivory)] no-underline text-sm hover:text-[var(--sage-soft)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-[var(--sage-mid)]/30 mt-[var(--space-7)] pt-[var(--space-5)]">
      <p class="text-[var(--sage-soft)] text-xs leading-relaxed">healthwelltech21 is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com.</p>
      <p class="text-[var(--sage-soft)] text-xs mt-[var(--space-3)]">&copy; {new Date().getFullYear()} healthwelltech21. All rights reserved.</p>
    </div>
  </div>
</footer>
