---
interface Props {
  title: string;
  slug: string;
  category: string;
  excerpt: string;
  date: string;
  heroImage: string;
  heroAlt: string;
  featured?: boolean;
}

const { title, slug, category, excerpt, date, heroImage, heroAlt, featured = false } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class:list={['post-card', { featured }]}>
  <a href={`/blog/${slug}`} class="post-card__link">
    <div class="post-card__image-wrapper">
      <img src={heroImage} alt={heroAlt} class="post-card__image" loading="lazy" />
    </div>
    <div class="post-card__content">
      <span class="post-card__category">{category}</span>
      <h3 class="post-card__title">{title}</h3>
      <p class="post-card__excerpt">{excerpt}</p>
      <time class="post-card__date" datetime={date}>{formattedDate}</time>
    </div>
  </a>
</article>

<style>
  .post-card {
    border: 1px solid var(--sage-soft);
    border-radius: 8px;
    background: var(--ivory);
    overflow: hidden;
    transition: border-color var(--duration-default) cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-card:hover {
    border-color: var(--sage-deep);
  }

  .post-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-card__image-wrapper {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--sage-whisper);
    position: relative;
  }

  .post-card.featured .post-card__image-wrapper {
    aspect-ratio: 4 / 5;
  }

  .post-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-default) cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-card:hover .post-card__image {
    transform: scale(1.03);
  }

  .post-card__content {
    padding: var(--space-5);
  }

  .post-card__category {
    display: block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--terracotta);
    margin-bottom: var(--space-2);
  }

  .post-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--space-3) 0;
    transition: transform var(--duration-default) cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-card:hover .post-card__title {
    transform: translateX(2px);
  }

  .post-card__excerpt {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--charcoal);
    margin: 0 0 var(--space-3) 0;
  }

  .post-card__date {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--stone);
  }
</style>
