---
interface Props {
  url: string;
  title: string;
  image: string;
}

const { url, title, image } = Astro.props;

const pinterestUrl = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(url)}&media=${encodeURIComponent(image)}&description=${encodeURIComponent(title)}`;
const instagramUrl = 'https://www.instagram.com/healthwelltech/';
---

<div class="social-share" aria-label="Share this post">
  <a
    href={pinterestUrl}
    class="social-share__btn"
    target="_blank"
    rel="noopener"
    aria-label="Share on Pinterest"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
    </svg>
  </a>

  <a
    href={instagramUrl}
    class="social-share__btn"
    target="_blank"
    rel="noopener"
    aria-label="Follow on Instagram"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
    </svg>
  </a>

  <button
    class="social-share__btn social-share__copy"
    aria-label="Copy link to clipboard"
    data-url={url}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
    </svg>
  </button>

  <span class="social-share__toast" aria-live="polite">Link copied!</span>
</div>

<style>
  .social-share {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    position: relative;
  }

  .social-share__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--sage-soft);
    background: var(--ivory);
    color: var(--charcoal);
    text-decoration: none;
    cursor: pointer;
    transition: border-color var(--duration-default) var(--ease-default),
                color var(--duration-default) var(--ease-default);
  }

  .social-share__btn:hover {
    border-color: var(--sage-deep);
    color: var(--sage-deep);
  }

  .social-share__toast {
    position: absolute;
    bottom: calc(100% + var(--space-2));
    left: 50%;
    transform: translateX(-50%);
    background: var(--charcoal);
    color: var(--ivory);
    font-family: var(--font-body);
    font-size: 0.75rem;
    padding: var(--space-2) var(--space-3);
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }

  .social-share__toast[data-visible] {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll('.social-share__copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url');
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);
        const toast = btn.closest('.social-share')?.querySelector('.social-share__toast');
        if (toast) {
          toast.setAttribute('data-visible', '');
          setTimeout(() => toast.removeAttribute('data-visible'), 2000);
        }
      } catch (e) {
        // Fallback for older browsers
        const input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }
    });
  });
</script>
